# Open Notebook local source-run configuration with SeekDB enabled
# Copy to .env.seekdb for local development.

OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-secret-string

OPEN_NOTEBOOK_SEEKDB_DSN=mysql://root:SeekDBRoot123%21@127.0.0.1:2881/open_notebook_ai
OPEN_NOTEBOOK_AI_CONFIG_BACKEND=seekdb
OPEN_NOTEBOOK_SEARCH_BACKEND=seekdb
OPEN_NOTEBOOK_SEEKDB_POOL_SIZE=5
OPEN_NOTEBOOK_SEEKDB_TIMEOUT_SECONDS=10
OPEN_NOTEBOOK_MULTIMODAL_INDEXING=best_effort
OPEN_NOTEBOOK_PAGE_IMAGE_CACHE_DIR=./data/page-cache
OPEN_NOTEBOOK_VLM_MAX_PAGES_PER_SOURCE=50
OPEN_NOTEBOOK_VLM_MIN_TEXT_CHARS=300

# Optional if you also start SeekDB via docker compose.
# SEEKDB_ROOT_PASSWORD=SeekDBRoot123!
#
# On Windows / Docker Desktop / WSL2, prefer the provided docker compose file,
# which now uses a named Docker volume for SeekDB data instead of a bind mount.

# Optional provider keys for local testing.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...
